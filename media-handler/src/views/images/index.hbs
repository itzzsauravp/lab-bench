<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <style>
      body {
        font-family: sans-serif;
        max-width: 600px;
        margin: 40px auto;
        padding: 20px;
        line-height: 1.6;
      }

      .form-group {
        margin-bottom: 15px;
      }

      label {
        display: block;
        font-weight: bold;
      }

      input[type="number"],
      input[type="file"] {
        width: 100%;
        padding: 8px;
        margin-top: 5px;
      }

      button {
        background: #007bff;
        color: white;
        border: none;
        padding: 10px 15px;
        cursor: pointer;
        border-radius: 4px;
      }

      button:hover {
        background: #0056b3;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
    </style>
  </head>

  <body>

    <form
      action="/crop/images/sync"
      method="POST"
      enctype="multipart/form-data"
    >

      <div class="form-group">
        <label for="image">Select Image:</label>
        <input type="file" name="image" id="image" accept="image/*" required />
      </div>

      <hr />

      <div class="grid">
        <div class="form-group">
          <label for="width">Width (px):</label>
          <input
            type="number"
            name="width"
            id="width"
            placeholder="e.g. 500"
            required
          />
        </div>
        <div class="form-group">
          <label for="height">Height (px):</label>
          <input
            type="number"
            name="height"
            id="height"
            placeholder="e.g. 500"
            required
          />
        </div>
        <div class="form-group">
          <label for="x">X Offset:</label>
          <input type="number" name="x" id="x" value="0" />
        </div>
        <div class="form-group">
          <label for="y">Y Offset:</label>
          <input type="number" name="y" id="y" value="0" />
        </div>
      </div>

      <button type="submit">Process Crop</button>
    </form>

  </body>

</html>
